# E2E test configuration — copy to .env.e2e and adjust.
# .env.e2e is gitignored; never commit real credentials.

# Supabase project the tests (and the dev server they spawn) run against.
# Leave unset to use the live project baked into src/lib/supabase.ts.
# For a local stack (`supabase start`, migrations applied), point both here:
#VITE_SUPABASE_URL=http://127.0.0.1:54321
#VITE_SUPABASE_ANON_KEY=<local anon key from `supabase status`>

# Dedicated test dealer account. Create/repair it once with:
#   node scripts/seed-test-dealer.mjs
# The email MUST contain "e2e" — the test helpers refuse to write to or
# clean up any other account as a safety guard.
E2E_DEALER_EMAIL=e2e.dealer@aquadealers.in
E2E_DEALER_PASSWORD=change-me-please

# Optional: service-role key. When set, the seed script creates the auth user
# with the email pre-confirmed (required if the Supabase project has email
# confirmations enabled). Never needed by the tests themselves.
#E2E_SUPABASE_SERVICE_ROLE_KEY=
